---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'Payment Processing App',
		description:
			'Serverless payment processing POC on AWS. Handles customer disbursements via PayPal, featuring authentication, request validation, audit logging, and Terraform-managed infrastructure.',
		tech: ['Python', 'AWS Lambda', 'API Gateway', 'DynamoDB', 'Cognito', 'Terraform', 'PayPal API'],
		link: 'https://github.com/lsraj/paymentApp',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Projects I've built" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<ul class="project-list">
				{projects.map((project) => (
					<li class="project-card">
						<h2>
							<a href={project.link} target="_blank" rel="noopener">{project.title}</a>
						</h2>
						<p>{project.description}</p>
						<ul class="tech">
							{project.tech.map((t) => <li>{t}</li>)}
						</ul>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 3em 1em;
	}
	.project-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5em;
		margin-top: 2em;
	}
	.project-card {
		padding: 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
	}
	.project-card h2 {
		margin: 0 0 0.5em;
		font-size: 1.3em;
	}
	.project-card h2 a {
		color: var(--accent);
		text-decoration: none;
	}
	.project-card h2 a:hover {
		text-decoration: underline;
	}
	.tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		list-style: none;
		padding: 0;
		margin: 1em 0 0;
	}
	.tech li {
		padding: 0.25em 0.75em;
		background: rgb(var(--gray-light));
		border-radius: 999px;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
	}
</style>
